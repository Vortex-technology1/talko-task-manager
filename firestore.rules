rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =====================
    // HELPER FUNCTIONS
    // =====================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function userId() {
      return request.auth.uid;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == 'management.talco@gmail.com';
    }
    
    function isCompanyMember(companyId) {
      return isAuthenticated() && 
        (isSuperAdmin() || exists(/databases/$(database)/documents/companies/$(companyId)/users/$(userId())));
    }
    
    function isCompanyOwner(companyId) {
      let company = get(/databases/$(database)/documents/companies/$(companyId));
      return isAuthenticated() && (isSuperAdmin() || company.data.ownerId == userId());
    }
    
    function isManagerOrOwner(companyId) {
      return isAuthenticated() && (isSuperAdmin() || (
        exists(/databases/$(database)/documents/companies/$(companyId)/users/$(userId())) &&
        get(/databases/$(database)/documents/companies/$(companyId)/users/$(userId())).data.role in ['owner', 'admin', 'manager']
      ));
    }

    // =====================
    // PERMISSION SYSTEM
    // Перевіряє чи є таб в allowedTabs юзера.
    // Якщо allowedTabs відсутній (null/не встановлено) — юзер бачить все (як раніше).
    // Якщо allowedTabs встановлено — перевіряємо наявність табу.
    // owner/admin/manager завжди мають доступ незалежно від allowedTabs.
    // =====================
    function getUserDoc(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/users/$(userId()));
    }

    function hasTabAccess(companyId, tabKey) {
      return isManagerOrOwner(companyId) ||
        isSuperAdmin() || (
          isCompanyMember(companyId) && (
            !('allowedTabs' in getUserDoc(companyId).data) ||
            getUserDoc(companyId).data.allowedTabs == null ||
            getUserDoc(companyId).data.allowedTabs.hasAny([tabKey])
          )
        );
    }

    function isValidString(field, maxLength) {
      return field is string && field.size() > 0 && field.size() <= maxLength;
    }

    // Перевірка: чи є юзер viewer в проєкті (тільки читання)
    function isProjectViewerOnly(companyId, projectId) {
      return exists(/databases/$(database)/documents/companies/$(companyId)/projects/$(projectId)/members/$(userId())) &&
        get(/databases/$(database)/documents/companies/$(companyId)/projects/$(projectId)/members/$(userId())).data.role == 'viewer';
    }

    function isViewerInTaskProject(companyId, projectId) {
      return projectId != null && projectId != '' && isProjectViewerOnly(companyId, projectId);
    }
    
    // =====================
    // COMPANIES
    // =====================
    match /companies/{companyId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(companyId));
      
      allow create: if isSuperAdmin() || (
        isAuthenticated() && 
        request.resource.data.ownerId == userId() &&
        isValidString(request.resource.data.name, 200)
      );
      
      allow update: if isSuperAdmin() || (
        isCompanyOwner(companyId) &&
        request.resource.data.ownerId == resource.data.ownerId
      );
      
      allow delete: if isCompanyOwner(companyId);
      
      // USERS
      match /users/{memberId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) || 
          (isAuthenticated() && memberId == userId());
        allow update: if isManagerOrOwner(companyId) || 
          (isAuthenticated() && memberId == userId() && 
           request.resource.data.role == resource.data.role) ||
          (isAuthenticated() && memberId == userId() &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['language', 'interfaceLang', 'telegramLanguage', 'updatedAt', 
                       'telegramChatId', 'telegramUserId', 'telegramCode',
                       'functionIds', 'primaryFunctionId', 'functionRoles',
                       'weeklyFunctionReportEnabled', 'lang']));
        allow delete: if isManagerOrOwner(companyId) && 
          resource.data.role != 'owner';
      }
      
      // ROLE PERMISSIONS
      match /rolePermissions/{roleId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyOwner(companyId);
      }

      // =====================
      // TASKS
      // tab: tasks, projects, myday
      // =====================
      match /tasks/{taskId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'tasks') && 
          isValidString(request.resource.data.title, 500) &&
          !(request.resource.data.projectId != null && request.resource.data.projectId != '' &&
            isProjectViewerOnly(companyId, request.resource.data.projectId));
        allow update: if !isViewerInTaskProject(companyId, resource.data.projectId) && (
          isManagerOrOwner(companyId) || 
          (hasTabAccess(companyId, 'tasks') && (
            resource.data.assigneeId == userId() ||
            resource.data.creatorId == userId() ||
            (resource.data.coExecutorIds != null && resource.data.coExecutorIds.hasAny([userId()]))
          )));
        allow delete: if !isViewerInTaskProject(companyId, resource.data.projectId) && (
          isManagerOrOwner(companyId) || 
          (hasTabAccess(companyId, 'tasks') && resource.data.creatorId == userId()));
        
        match /comments/{commentId} {
          allow read: if isCompanyMember(companyId);
          allow create: if hasTabAccess(companyId, 'tasks') &&
            !isViewerInTaskProject(companyId, get(/databases/$(database)/documents/companies/$(companyId)/tasks/$(taskId)).data.projectId);
          allow update: if isManagerOrOwner(companyId) ||
            (isAuthenticated() && isCompanyMember(companyId) && resource.data.authorId == userId());
          allow delete: if isManagerOrOwner(companyId) ||
            (isAuthenticated() && isCompanyMember(companyId) && resource.data.authorId == userId());
        }
        
        match /history/{historyId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
        }
      }
      
      // TASKS ARCHIVE
      match /tasksArchive/{taskId} {
        allow read: if isCompanyMember(companyId);
        allow create, delete: if hasTabAccess(companyId, 'tasks');
      }
      
      // REGULAR TASKS — tab: regular
      match /regularTasks/{taskId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'regular') &&
          isValidString(request.resource.data.title, 500);
        allow update: if hasTabAccess(companyId, 'regular');
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // FUNCTIONS — tab: tasks (функції співробітників)
      match /functions/{functionId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) &&
          isValidString(request.resource.data.name, 200);
        allow update: if isManagerOrOwner(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // FUNCTION CONNECTIONS
      match /functionConnections/{connectionId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }
      
      // PROCESS TEMPLATES — tab: processes
      match /processTemplates/{templateId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'processes') &&
          isValidString(request.resource.data.name, 200);
        allow update: if hasTabAccess(companyId, 'processes');
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // PROCESSES — tab: processes
      match /processes/{processId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'processes') &&
          isValidString(request.resource.data.name, 500);
        allow update: if hasTabAccess(companyId, 'processes');
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // COORDINATIONS — tab: coordination
      match /coordinations/{coordId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'coordination') &&
          isValidString(request.resource.data.name, 500);
        allow update: if hasTabAccess(companyId, 'coordination');
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // PROJECTS — tab: projects
      match /projects/{projectId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'projects') &&
          isValidString(request.resource.data.name, 200);
        allow update: if hasTabAccess(companyId, 'projects');
        allow delete: if isManagerOrOwner(companyId);
      }

      // ESTIMATE NORMS — tab: estimate
      match /estimate_norms/{normId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if hasTabAccess(companyId, 'estimate');
        allow delete: if isManagerOrOwner(companyId);
      }

      // PROJECT ESTIMATES — tab: estimate
      match /project_estimates/{estimateId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if hasTabAccess(companyId, 'estimate');
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // COMPLETED TASKS
      match /completedTasks/{taskId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId);
      }
      
      // TASK TEMPLATES — tab: tasks
      match /taskTemplates/{templateId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'tasks') &&
          isValidString(request.resource.data.title, 500);
        allow update: if hasTabAccess(companyId, 'tasks');
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // INCIDENTS — tab: control
      match /incidents/{incidentId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'control') &&
          isValidString(request.resource.data.title, 500);
        allow update: if hasTabAccess(companyId, 'control');
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // DAILY SNAPSHOTS
      match /snapshots/{snapshotId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if isManagerOrOwner(companyId);
      }
      
      // DECISION LOG
      match /decisions/{decisionId} {
        allow read: if isManagerOrOwner(companyId);
        allow create: if isCompanyMember(companyId);
      }
      
      // BUSINESS STRUCTURE
      match /bizStructure/{document=**} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
      
      match /bizStructureBackups/{document=**} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
      
      match /bizStructureTest/{document=**} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
      
      // PROJECT TEMPLATES, STANDARDS, QC — tab: projects
      match /projectTemplates/{templateId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasTabAccess(companyId, 'projects');
      }
      
      match /workStandards/{standardId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
      
      match /qualityChecks/{qcId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'projects') &&
          isValidString(request.resource.data.projectId, 200);
        allow update: if hasTabAccess(companyId, 'projects');
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // PROJECT STAGES & MATERIALS — tab: projects
      match /projectStages/{stageId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'projects') &&
          isValidString(request.resource.data.name, 200) &&
          isValidString(request.resource.data.projectId, 200);
        allow update: if hasTabAccess(companyId, 'projects');
        allow delete: if isManagerOrOwner(companyId);
      }
      
      match /projectMaterials/{materialId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'projects') &&
          isValidString(request.resource.data.name, 200) &&
          isValidString(request.resource.data.projectId, 200);
        allow update: if hasTabAccess(companyId, 'projects');
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // STATISTICS / METRICS — tab: statistics
      match /metrics/{metricId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if hasTabAccess(companyId, 'statistics');
        allow delete: if isManagerOrOwner(companyId);
      }
      
      match /metricEntries/{entryId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'statistics');
        allow update: if hasTabAccess(companyId, 'statistics') &&
          (resource.data.createdBy == userId() || isManagerOrOwner(companyId));
        allow delete: if isManagerOrOwner(companyId);
      }
      
      match /metricTargets/{targetId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasTabAccess(companyId, 'statistics');
      }
      
      match /metricAggregates/{aggId} {
        allow read: if isCompanyMember(companyId);
      }
      
      match /metricInsights/{insightId} {
        allow read: if isManagerOrOwner(companyId);
      }
      
      match /metricAuditLog/{logId} {
        allow read: if isManagerOrOwner(companyId);
      }

      // =====================
      // CRM — tab: crm
      // =====================
      match /contacts/{contactId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if hasTabAccess(companyId, 'crm');
        allow delete: if isManagerOrOwner(companyId);
      }

      match /deals/{dealId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if hasTabAccess(companyId, 'crm');
        allow delete: if isManagerOrOwner(companyId);
        match /history/{histId} {
          allow read: if isCompanyMember(companyId);
          allow create: if hasTabAccess(companyId, 'crm');
        }
      }

      match /pipelines/{pipelineId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      match /crm_clients/{clientId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if hasTabAccess(companyId, 'crm');
        allow delete: if isManagerOrOwner(companyId);
      }

      match /crm_deals/{dealId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'crm');
        allow update: if isManagerOrOwner(companyId) ||
          (hasTabAccess(companyId, 'crm') && (
            resource.data.assigneeId == userId() ||
            resource.data.responsibleId == userId()
          ));
        allow delete: if isManagerOrOwner(companyId);
        match /history/{histId} {
          allow read: if isCompanyMember(companyId);
          allow create: if hasTabAccess(companyId, 'crm');
          allow update, delete: if false;
        }
        match /tasks/{taskId} {
          allow read: if isCompanyMember(companyId);
          allow create: if hasTabAccess(companyId, 'crm');
          allow update: if isManagerOrOwner(companyId) ||
            (hasTabAccess(companyId, 'crm') && resource.data.assigneeId == userId());
          allow delete: if isManagerOrOwner(companyId);
        }
        match /files/{fileId} {
          allow read: if isCompanyMember(companyId);
          allow create: if hasTabAccess(companyId, 'crm');
          allow delete: if isManagerOrOwner(companyId);
        }
      }

      match /crm_pipeline/{pipelineId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      match /crm_pipelines/{pipelineId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      match /crm_forms/{formId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      match /crm_activities/{activityId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'crm');
        allow update: if isManagerOrOwner(companyId) ||
          (hasTabAccess(companyId, 'crm') && resource.data.userId == userId());
        allow delete: if isManagerOrOwner(companyId);
      }

      match /crm_stats/{docId} {
        allow read: if isManagerOrOwner(companyId);
        allow write: if hasTabAccess(companyId, 'crm');
      }

      match /automation_rules/{ruleId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      match /contacts/{contactId}/messages/{msgId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if hasTabAccess(companyId, 'crm');
        allow delete: if isManagerOrOwner(companyId);
      }

      // =====================
      // MARKETING — tab: marketing
      // =====================
      match /landingPages/{pageId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if hasTabAccess(companyId, 'marketing');
      }

      match /funnels/{funnelId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if hasTabAccess(companyId, 'marketing');
      }

      match /broadcasts/{broadcastId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if hasTabAccess(companyId, 'marketing');
        allow delete: if isManagerOrOwner(companyId);
      }

      // =====================
      // BOTS — tab: bots
      // =====================
      match /bots/{botId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if hasTabAccess(companyId, 'bots');
        match /flows/{flowId} {
          allow read: if isCompanyMember(companyId);
          allow create, update, delete: if hasTabAccess(companyId, 'bots');
          match /nodePrompts/{nodeId} {
            allow read: if isCompanyMember(companyId);
            allow write: if hasTabAccess(companyId, 'bots');
          }
          match /canvasData/{docId} {
            allow read: if isCompanyMember(companyId);
            allow write: if hasTabAccess(companyId, 'bots');
          }
        }
      }

      match /flows/{flowId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if hasTabAccess(companyId, 'bots');
        match /nodePrompts/{nodeId} {
          allow read: if isCompanyMember(companyId);
          allow write: if hasTabAccess(companyId, 'bots');
        }
        match /canvasData/{docId} {
          allow read: if isCompanyMember(companyId);
          allow write: if hasTabAccess(companyId, 'bots');
        }
      }

      match /leads/{leadId} {
        allow read: if isManagerOrOwner(companyId);
        allow create: if isCompanyMember(companyId);
      }

      match /sessions/{sessionId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId);
      }

      match /cbCache/{cbId} {
        allow read, write: if false;
      }

      match /_finish_locks/{lockId} {
        allow read: if isManagerOrOwner(companyId);
        allow write: if false;
      }

      // =====================
      // SITES — tab: sites
      // =====================
      match /sites/{siteId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if hasTabAccess(companyId, 'sites');
        match /blocks/{blockId} {
          allow read: if isCompanyMember(companyId);
          allow write: if hasTabAccess(companyId, 'sites');
        }
      }

      match /site_forms/{formId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if hasTabAccess(companyId, 'sites');
      }

      match /form_submissions/{submissionId} {
        allow read: if isCompanyMember(companyId);
        allow create: if request.resource.data.keys().hasAll(['submittedAt', 'formId'])
                      && request.resource.data.size() < 10240;
        allow update: if isCompanyMember(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }

      // EVENTS
      match /events/{eventId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId) &&
          isValidString(request.resource.data.type, 100);
        allow update: if isCompanyMember(companyId) &&
          request.resource.data.type == resource.data.type;
        allow delete: if isSuperAdmin();
      }

      // =====================
      // FINANCE — tab: finance
      // =====================
      match /finance_transactions/{txId} {
        allow read: if hasTabAccess(companyId, 'finance');
        allow create: if hasTabAccess(companyId, 'finance');
        allow update, delete: if isManagerOrOwner(companyId);
      }

      match /finance_categories/{catId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasTabAccess(companyId, 'finance');
      }

      match /finance_budgets/{budgetId} {
        allow read: if hasTabAccess(companyId, 'finance');
        allow write: if isCompanyOwner(companyId);
      }

      match /finance_accounts/{accId} {
        allow read: if hasTabAccess(companyId, 'finance');
        allow write: if hasTabAccess(companyId, 'finance');
      }

      match /finance_recurring/{recId} {
        allow read: if hasTabAccess(companyId, 'finance');
        allow write: if hasTabAccess(companyId, 'finance');
      }

      match /finance_function_budgets/{fbudId} {
        allow read: if hasTabAccess(companyId, 'finance');
        allow write: if isCompanyOwner(companyId);
      }

      match /finance_ai_history/{aiId} {
        allow read, write: if hasTabAccess(companyId, 'finance');
      }

      match /finance_settings/{doc} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasTabAccess(companyId, 'finance');
      }

      match /finance_transfers/{transferId} {
        allow read, write: if hasTabAccess(companyId, 'finance');
      }

      match /finance_invoices/{invoiceId} {
        allow read: if hasTabAccess(companyId, 'finance');
        allow create: if hasTabAccess(companyId, 'finance');
        allow update, delete: if isManagerOrOwner(companyId);
      }

      // =====================
      // BOOKING — tab: booking
      // =====================
      match /booking_calendars/{calendarId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if hasTabAccess(companyId, 'booking');
      }

      match /booking_schedules/{scheduleId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if hasTabAccess(companyId, 'booking');
      }

      match /booking_groups/{groupId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if hasTabAccess(companyId, 'booking');
      }

      match /booking_appointments/{appointmentId} {
        allow read: if hasTabAccess(companyId, 'booking');
        allow create: if false; // Admin SDK only
        allow update: if hasTabAccess(companyId, 'booking');
        allow delete: if isManagerOrOwner(companyId);
      }

      // =====================
      // WAREHOUSE — tab: warehouse
      // =====================
      match /warehouse_items/{itemId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'warehouse') &&
          isValidString(request.resource.data.name, 200);
        allow update: if hasTabAccess(companyId, 'warehouse');
        allow delete: if isManagerOrOwner(companyId);
      }

      match /warehouse_operations/{opId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'warehouse') &&
          request.resource.data.keys().hasAll(['itemId', 'type', 'qty']) &&
          request.resource.data.qty is number &&
          request.resource.data.qty > 0;
        allow update, delete: if isManagerOrOwner(companyId);
      }

      match /warehouse_stock/{stockId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasTabAccess(companyId, 'warehouse');
      }

      match /warehouse_stock_by_location/{docId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasTabAccess(companyId, 'warehouse');
      }

      match /warehouse_locations/{locationId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if hasTabAccess(companyId, 'warehouse');
      }

      match /warehouse_suppliers/{supplierId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if hasTabAccess(companyId, 'warehouse');
      }

      // =====================
      // SALES — tab: sales
      // =====================
      match /sales/{saleId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if hasTabAccess(companyId, 'sales');
        allow delete: if isManagerOrOwner(companyId);
      }

      match /sales_purchase_orders/{orderId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'sales');
        allow update: if hasTabAccess(companyId, 'sales');
        allow delete: if isCompanyOwner(companyId);
      }

      match /sales_realizations/{realizationId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'sales');
        allow update: if hasTabAccess(companyId, 'sales');
        allow delete: if isCompanyOwner(companyId);
      }

      match /sales_debtors/{debtorId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasTabAccess(companyId, 'sales');
        allow update: if hasTabAccess(companyId, 'sales');
        allow delete: if false; // immutable
      }

      match /price_lists/{priceListId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isCompanyOwner(companyId);
      }

      // =====================
      // ESTIMATE — tab: estimate
      // =====================
      match /estimates/{estId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if hasTabAccess(companyId, 'estimate');
        allow delete: if isManagerOrOwner(companyId);
        match /{sub=**} {
          allow read: if isCompanyMember(companyId);
          allow write: if hasTabAccess(companyId, 'estimate');
        }
      }

      match /standards/{stdId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      match /norm_definitions/{normId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
        match /{sub=**} {
          allow read: if isCompanyMember(companyId);
          allow write: if isManagerOrOwner(companyId);
        }
      }

      // =====================
      // ANALYTICS / CONTROL — tab: analytics, control
      // =====================
      match /metrics_daily/{mId} {
        allow read: if hasTabAccess(companyId, 'analytics') || hasTabAccess(companyId, 'statistics');
        allow create, update: if hasTabAccess(companyId, 'statistics');
        allow delete: if isManagerOrOwner(companyId);
      }

      match /escalations/{escId} {
        allow read: if isManagerOrOwner(companyId);
        allow create: if isCompanyMember(companyId);
        allow update: if false; // Admin SDK only
        allow delete: if isManagerOrOwner(companyId);
      }

      match /scheduledTasks/{taskId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }

      // =====================
      // ACTIVITY LOG (Реєстр — tab: control)
      // =====================
      match /activity_log/{logId} {
        allow read: if hasTabAccess(companyId, 'control') || isManagerOrOwner(companyId);
        allow create: if isCompanyMember(companyId) &&
          request.resource.data.userId == userId();
        allow update, delete: if false; // immutable
      }

      // =====================
      // SETTINGS
      // =====================
      match /settings/{settingId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId);
      }

      match /aiUsageLog/{docId} {
        allow read: if isManagerOrOwner(companyId);
        allow write: if false; // Admin SDK only
      }

      match /ai_recommendations/{docId} {
        allow read, write: if isManagerOrOwner(companyId);
      }

      match /weekly_report_log/{docId} {
        allow read: if isManagerOrOwner(companyId);
        allow write: if false; // Admin SDK only
      }

      match /sa_notes/{noteId} {
        allow read, write: if isSuperAdmin();
      }

      match /_session_locks/{lockId} {
        allow read, write: if false;
      }

      match /bookings/{bookingId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if hasTabAccess(companyId, 'booking');
        allow delete: if isManagerOrOwner(companyId);
      }

      // FALLBACK
      match /{subcollection}/{docId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
    }

    // =====================
    // INVITES
    // =====================
    match /invites/{inviteId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        request.auth.token.email == resource.data.email ||
        isManagerOrOwner(resource.data.companyId)
      );
      allow create: if isSuperAdmin() || (
        isAuthenticated() && 
        isManagerOrOwner(request.resource.data.companyId) &&
        isValidString(request.resource.data.email, 255)
      );
      allow update: if isAuthenticated() && (
        isSuperAdmin() || (
          request.resource.data.accepted == true &&
          request.auth.token.email == resource.data.email
        )
      );
      allow delete: if isSuperAdmin() || (
        isAuthenticated() && 
        isManagerOrOwner(resource.data.companyId)
      );
    }
    
    // =====================
    // USERS (global profile)
    // =====================
    match /users/{docUserId} {
      allow read: if isAuthenticated() && (docUserId == userId() || isSuperAdmin());
      allow write: if isAuthenticated() && (docUserId == userId() || isSuperAdmin());
    }
    
    // =====================
    // SETTINGS (global)
    // =====================
    match /settings/{doc} {
      allow read: if isSuperAdmin() || (isAuthenticated() && doc != 'main');
      allow write: if isSuperAdmin();
    }
    match /settings/{doc}/{sub=**} {
      allow read: if isSuperAdmin() || isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // =====================
    // TELEGRAM INDEX
    // =====================
    match /telegramIndex/{doc} {
      allow read, write: if request.auth != null;
    }

    // =====================
    // WEBHOOK LOCKS (Admin SDK only)
    // =====================
    match /_finish_locks/{lockId} {
      allow read, write: if false;
    }

    match /companies/{companyId}/_tlocks/{lockId} {
      allow read, write: if false;
    }
  }
}
