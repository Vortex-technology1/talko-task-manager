rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =====================
    // HELPER FUNCTIONS
    // =====================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function userId() {
      return request.auth.uid;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == 'management.talco@gmail.com';
    }
    
    function isCompanyMember(companyId) {
      return isAuthenticated() && 
        (isSuperAdmin() || exists(/databases/$(database)/documents/companies/$(companyId)/users/$(userId())));
    }
    
    function isCompanyOwner(companyId) {
      let company = get(/databases/$(database)/documents/companies/$(companyId));
      return isAuthenticated() && (isSuperAdmin() || company.data.ownerId == userId());
    }
    
    function isManagerOrOwner(companyId) {
      return isAuthenticated() && (isSuperAdmin() || (
        exists(/databases/$(database)/documents/companies/$(companyId)/users/$(userId())) &&
        get(/databases/$(database)/documents/companies/$(companyId)/users/$(userId())).data.role in ['owner', 'admin', 'manager']
      ));
    }
    
    function isValidString(field, maxLength) {
      return field is string && field.size() > 0 && field.size() <= maxLength;
    }
    
    // =====================
    // COMPANIES
    // =====================
    match /companies/{companyId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isCompanyMember(companyId));
      
      allow create: if isSuperAdmin() || (
        isAuthenticated() && 
        request.resource.data.ownerId == userId() &&
        isValidString(request.resource.data.name, 200)
      );
      
      allow update: if isSuperAdmin() || (
        isCompanyOwner(companyId) &&
        request.resource.data.ownerId == resource.data.ownerId
      );
      
      allow delete: if isCompanyOwner(companyId);
      
      // USERS
      match /users/{memberId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) || 
          (isAuthenticated() && memberId == userId());
        allow update: if isManagerOrOwner(companyId) || 
          (isAuthenticated() && memberId == userId() && 
           request.resource.data.role == resource.data.role) ||
          // Юзер може зберегти свою мову інтерфейсу (для weekly-report)
          (isAuthenticated() && memberId == userId() &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['language', 'interfaceLang', 'updatedAt']));
        allow delete: if isManagerOrOwner(companyId) && 
          resource.data.role != 'owner';
      }
      
      // ROLE PERMISSIONS
      match /rolePermissions/{roleId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyOwner(companyId);
      }

      // TASKS
      match /tasks/{taskId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId) && 
          isValidString(request.resource.data.title, 500);
        allow update: if isManagerOrOwner(companyId) || 
          (isCompanyMember(companyId) && (
            resource.data.assigneeId == userId() ||
            resource.data.creatorId == userId() ||
            (resource.data.coExecutorIds != null && resource.data.coExecutorIds.hasAny([userId()]))
          ));
        allow delete: if isManagerOrOwner(companyId) || 
          (isCompanyMember(companyId) && resource.data.creatorId == userId());
        
        match /comments/{commentId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update: if isManagerOrOwner(companyId) ||
            (isAuthenticated() && isCompanyMember(companyId) && resource.data.authorId == userId());
          allow delete: if isManagerOrOwner(companyId) ||
            (isAuthenticated() && isCompanyMember(companyId) && resource.data.authorId == userId());
        }
        
        match /history/{historyId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
        }
      }
      
      // TASKS ARCHIVE
      match /tasksArchive/{taskId} {
        allow read: if isCompanyMember(companyId);
        allow create, delete: if isCompanyMember(companyId);
      }
      
      // REGULAR TASKS
      match /regularTasks/{taskId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) &&
          isValidString(request.resource.data.title, 500);
        allow update: if isManagerOrOwner(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // FUNCTIONS
      match /functions/{functionId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) &&
          isValidString(request.resource.data.name, 200);
        allow update: if isManagerOrOwner(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // FUNCTION CONNECTIONS
      match /functionConnections/{connectionId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }
      
      // PROCESS TEMPLATES
      match /processTemplates/{templateId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) &&
          isValidString(request.resource.data.name, 200);
        allow update: if isManagerOrOwner(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // PROCESSES
      match /processes/{processId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId) &&
          isValidString(request.resource.data.name, 500);
        allow update: if isCompanyMember(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // COORDINATIONS
      match /coordinations/{coordId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) &&
          isValidString(request.resource.data.name, 500);
        allow update: if isManagerOrOwner(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // PROJECTS
      match /projects/{projectId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) &&
          isValidString(request.resource.data.name, 200);
        allow update: if isManagerOrOwner(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // COMPLETED TASKS
      match /completedTasks/{taskId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId);
      }
      
      // TASK TEMPLATES
      match /taskTemplates/{templateId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) &&
          isValidString(request.resource.data.title, 500);
        allow update: if isManagerOrOwner(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // INCIDENTS
      match /incidents/{incidentId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) &&
          isValidString(request.resource.data.title, 500);
        allow update: if isManagerOrOwner(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // DAILY SNAPSHOTS
      match /snapshots/{snapshotId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if isManagerOrOwner(companyId);
      }
      
      // DECISION LOG
      match /decisions/{decisionId} {
        allow read: if isManagerOrOwner(companyId);
        allow create: if isCompanyMember(companyId);
      }
      
      // BUSINESS STRUCTURE
      match /bizStructure/{document=**} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
      
      match /bizStructureBackups/{document=**} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
      
      match /bizStructureTest/{document=**} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
      
      // PROJECT TEMPLATES, STANDARDS, QC
      match /projectTemplates/{templateId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
      
      match /workStandards/{standardId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
      
      match /qualityChecks/{qcId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId) &&
          isValidString(request.resource.data.projectId, 200);
        allow update: if isCompanyMember(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // PROJECT STAGES & MATERIALS
      match /projectStages/{stageId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) &&
          isValidString(request.resource.data.name, 200) &&
          isValidString(request.resource.data.projectId, 200);
        allow update: if isCompanyMember(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      match /projectMaterials/{materialId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId) &&
          isValidString(request.resource.data.name, 200) &&
          isValidString(request.resource.data.projectId, 200);
        allow update: if isCompanyMember(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }
      
      // STATISTICS / METRICS
      match /metrics/{metricId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }
      
      match /metricEntries/{entryId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update: if isCompanyMember(companyId) &&
          (resource.data.createdBy == userId() || isManagerOrOwner(companyId));
        allow delete: if isManagerOrOwner(companyId);
      }
      
      match /metricTargets/{targetId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
      
      match /metricAggregates/{aggId} {
        allow read: if isCompanyMember(companyId);
      }
      
      match /metricInsights/{insightId} {
        allow read: if isManagerOrOwner(companyId);
      }
      
      match /metricAuditLog/{logId} {
        allow read: if isManagerOrOwner(companyId);
      }

      // CRM — CONTACTS
      match /contacts/{contactId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update: if isCompanyMember(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }

      // CRM — DEALS (legacy)
      match /deals/{dealId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update: if isCompanyMember(companyId);
        allow delete: if isManagerOrOwner(companyId);
        match /history/{histId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
        }
      }

      // CRM — PIPELINES (legacy)
      match /pipelines/{pipelineId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      // MARKETING — LANDING PAGES
      match /landingPages/{pageId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      // MARKETING — FUNNELS
      match /funnels/{funnelId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      // BOTS
      match /bots/{botId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
        match /flows/{flowId} {
          allow read: if isCompanyMember(companyId);
          allow create, update, delete: if isManagerOrOwner(companyId);
          match /nodePrompts/{nodeId} {
            allow read: if isCompanyMember(companyId);
            allow write: if isManagerOrOwner(companyId);
          }
          match /canvasData/{docId} {
            allow read: if isCompanyMember(companyId);
            allow write: if isManagerOrOwner(companyId);
          }
        }
      }

      // BOTS — FLOWS (root level)
      match /flows/{flowId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
        match /nodePrompts/{nodeId} {
          allow read: if isCompanyMember(companyId);
          allow write: if isManagerOrOwner(companyId);
        }
        match /canvasData/{docId} {
          allow read: if isCompanyMember(companyId);
          allow write: if isManagerOrOwner(companyId);
        }
      }

      // BOTS — LEADS
      match /leads/{leadId} {
        allow read: if isManagerOrOwner(companyId);
        allow create: if isCompanyMember(companyId);
      }

      // BOTS — SESSIONS
      match /sessions/{sessionId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId);
      }

      // BOTS — CALLBACK CACHE (Admin SDK only)
      match /cbCache/{cbId} {
        allow read, write: if false;
      }

      // WEBHOOK — IDEMPOTENCY LOCKS
      match /_finish_locks/{lockId} {
        allow read: if isManagerOrOwner(companyId);
        allow write: if false;
      }

      // CRM — CLIENTS
      match /crm_clients/{clientId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update: if isCompanyMember(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }

      // CRM — DEALS
      match /crm_deals/{dealId} {
        allow read: if isManagerOrOwner(companyId) ||
          (isCompanyMember(companyId) && (
            resource.data.assigneeId == userId() ||
            resource.data.responsibleId == userId() ||
            resource.data.createdBy == userId()
          ));
        allow create: if isCompanyMember(companyId);
        allow update: if isManagerOrOwner(companyId) ||
          (isCompanyMember(companyId) && (
            resource.data.assigneeId == userId() ||
            resource.data.responsibleId == userId()
          ));
        allow delete: if isManagerOrOwner(companyId);
        match /history/{histId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update, delete: if false;
        }
        match /tasks/{taskId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update: if isManagerOrOwner(companyId) ||
            (isCompanyMember(companyId) && resource.data.assigneeId == userId());
          allow delete: if isManagerOrOwner(companyId);
        }
      }

      // CRM — PIPELINES
      match /crm_pipeline/{pipelineId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      match /crm_pipelines/{pipelineId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      // CRM — FORMS
      match /crm_forms/{formId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      // CRM — ACTIVITIES
      match /crm_activities/{activityId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update: if isManagerOrOwner(companyId) ||
          (isCompanyMember(companyId) && resource.data.userId == userId());
        allow delete: if isManagerOrOwner(companyId);
      }

      // CRM — STATS
      match /crm_stats/{docId} {
        allow read: if isManagerOrOwner(companyId);
        allow write: if isCompanyMember(companyId);
      }

      // AUTOMATION RULES
      match /automation_rules/{ruleId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      // CONTACTS — MESSAGES
      match /contacts/{contactId}/messages/{msgId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update: if isCompanyMember(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }

      // BROADCASTS
      match /broadcasts/{broadcastId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      // SITES
      match /sites/{siteId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
        match /blocks/{blockId} {
          allow read: if isCompanyMember(companyId);
          allow write: if isManagerOrOwner(companyId);
        }
      }

      // SITE FORMS + SUBMISSIONS
      match /site_forms/{formId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      match /form_submissions/{submissionId} {
        allow read: if isCompanyMember(companyId);
        // Публічний create — клієнти подають форми без авторизації
        allow create: if request.resource.data.keys().hasAll(['submittedAt', 'formId'])
                      && request.resource.data.size() < 10240;
        allow update: if isCompanyMember(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }

      // EVENTS
      match /events/{eventId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId) &&
          isValidString(request.resource.data.type, 100);
        allow update: if isCompanyMember(companyId) &&
          request.resource.data.type == resource.data.type;
        allow delete: if isSuperAdmin();
      }

      // =====================
      // FINANCE
      // =====================
      match /finance_transactions/{txId} {
        allow read: if isManagerOrOwner(companyId);
        allow create: if isCompanyMember(companyId) && (
          isManagerOrOwner(companyId) ||
          (request.resource.data.type == 'expense' &&
           (request.resource.data.projectId != null || request.resource.data.taskId != null))
        );
        allow update, delete: if isManagerOrOwner(companyId);
      }

      match /finance_categories/{catId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }

      match /finance_budgets/{budgetId} {
        allow read: if isManagerOrOwner(companyId);
        allow write: if isCompanyOwner(companyId);
      }

      match /finance_accounts/{accId} {
        allow read, write: if isManagerOrOwner(companyId);
      }

      match /finance_recurring/{recId} {
        allow read, write: if isManagerOrOwner(companyId);
      }

      match /finance_function_budgets/{fbudId} {
        allow read: if isManagerOrOwner(companyId);
        allow write: if isCompanyOwner(companyId);
      }

      match /finance_ai_history/{aiId} {
        allow read, write: if isManagerOrOwner(companyId);
      }

      match /finance_settings/{doc} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }

      match /finance_transfers/{transferId} {
        allow read, write: if isManagerOrOwner(companyId);
      }

      match /finance_invoices/{invoiceId} {
        allow read: if isManagerOrOwner(companyId);
        allow create: if isCompanyMember(companyId);
        allow update, delete: if isManagerOrOwner(companyId);
      }

      // =====================
      // BOOKING MODULE
      // Записи клієнтів відбуваються через /api/booking (Admin SDK)
      // Rules захищають прямий JS SDK доступ від співробітників
      // =====================

      // Налаштування календарів — тільки менеджер+
      match /booking_calendars/{calendarId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      // Розклади — тільки менеджер+
      match /booking_schedules/{scheduleId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      // Групи календарів — тільки менеджер+
      match /booking_groups/{groupId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      // Записи клієнтів:
      // - READ: тільки менеджер+ (містить ПІБ, email, телефон клієнтів → GDPR)
      // - CREATE: тільки через Admin SDK (/api/booking) → allow create: if false
      // - UPDATE (confirm/cancel): тільки менеджер+ через UI або Admin SDK
      match /booking_appointments/{appointmentId} {
        allow read: if isManagerOrOwner(companyId);
        allow create: if false; // Admin SDK only (/api/booking?action=create)
        allow update: if isManagerOrOwner(companyId); // confirm/cancel через UI
        allow delete: if isManagerOrOwner(companyId);
      }

      // =====================
      // WAREHOUSE MODULE
      // =====================

      // Товари — manager може редагувати каталог, member читає
      match /warehouse_items/{itemId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isManagerOrOwner(companyId) &&
          isValidString(request.resource.data.name, 200);
        allow update: if isManagerOrOwner(companyId);
        allow delete: if isManagerOrOwner(companyId);
      }

      // Операції (прихід/видача/списання) — member може додавати
      // (комірник не обов'язково є менеджером)
      match /warehouse_operations/{opId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId) &&
          request.resource.data.keys().hasAll(['itemId', 'type', 'qty']) &&
          request.resource.data.qty is number &&
          request.resource.data.qty > 0;
        // update/delete — тільки менеджер (виправлення помилок)
        allow update, delete: if isManagerOrOwner(companyId);
      }

      // Залишки — оновлює тільки серверна логіка (warehouse.js Admin SDK)
      // Клієнт може читати для відображення дашборду
      match /warehouse_stock/{stockId} {
        allow read: if isCompanyMember(companyId);
        allow write: if false; // Admin SDK only (api/warehouse.js)
      }

      // Локації складу — тільки менеджер+
      match /warehouse_locations/{locationId} {
        allow read: if isCompanyMember(companyId);
        allow create, update, delete: if isManagerOrOwner(companyId);
      }

      // =====================
      // ACTIVITY LOG
      // Лог активності співробітників — member може писати свої дії
      // =====================
      match /activity_log/{logId} {
        allow read: if isManagerOrOwner(companyId);
        allow create: if isCompanyMember(companyId) &&
          request.resource.data.userId == userId();
        allow update, delete: if false; // immutable log
      }

      // =====================
      // SETTINGS (per company)
      // Onboarding, AI assistants config, integrations
      // =====================
      match /settings/{settingId} {
        // Onboarding прогрес — будь-який member може зберігати свій прогрес
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId);
      }

      // =====================
      // AI USAGE LOG
      // =====================
      match /aiUsageLog/{docId} {
        allow read: if isManagerOrOwner(companyId);
        allow write: if false; // Admin SDK only (ai-proxy.js)
      }

      // AI RECOMMENDATIONS
      match /ai_recommendations/{docId} {
        allow read, write: if isManagerOrOwner(companyId);
      }

      // WEEKLY REPORT LOG
      match /weekly_report_log/{docId} {
        allow read: if isManagerOrOwner(companyId);
        allow write: if false; // Admin SDK only
      }

      // SUPERADMIN NOTES
      match /sa_notes/{noteId} {
        allow read, write: if isSuperAdmin();
      }

      // SESSION LOCKS (webhook)
      match /_session_locks/{lockId} {
        allow read, write: if false;
      }

      // =====================
      // FALLBACK — нові колекції до деплою специфічних правил
      // Вужчий ніж раніше: read тільки member, write тільки manager
      // =====================
      match /{subcollection}/{docId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isManagerOrOwner(companyId);
      }
    }

    // =====================
    // INVITES
    // =====================
    match /invites/{inviteId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        request.auth.token.email == resource.data.email ||
        isManagerOrOwner(resource.data.companyId)
      );
      allow create: if isSuperAdmin() || (
        isAuthenticated() && 
        isManagerOrOwner(request.resource.data.companyId) &&
        isValidString(request.resource.data.email, 255)
      );
      allow update: if isAuthenticated() && (
        isSuperAdmin() || (
          request.resource.data.accepted == true &&
          request.auth.token.email == resource.data.email
        )
      );
      allow delete: if isSuperAdmin() || (
        isAuthenticated() && 
        isManagerOrOwner(resource.data.companyId)
      );
    }
    
    // =====================
    // USERS (глобальна — профіль, Google Calendar токени)
    // =====================
    match /users/{docUserId} {
      allow read: if isAuthenticated() && (docUserId == userId() || isSuperAdmin());
      allow write: if isAuthenticated() && (docUserId == userId() || isSuperAdmin());
    }
    
    // =====================
    // SETTINGS (глобальні — AI assistants config)
    // =====================
    match /settings/{doc} {
      allow read: if isSuperAdmin() || (isAuthenticated() && doc != 'main');
      allow write: if isSuperAdmin();
    }
    match /settings/{doc}/{sub=**} {
      allow read: if isSuperAdmin() || isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // =====================
    // TELEGRAM INDEX
    // =====================
    match /telegramIndex/{doc} {
      allow read, write: if request.auth != null;
    }

    // =====================
    // WEBHOOK LOCKS (Admin SDK only)
    // =====================
    match /_finish_locks/{lockId} {
      allow read, write: if false;
    }

    match /companies/{companyId}/_tlocks/{lockId} {
      allow read, write: if false;
    }
  }
}
