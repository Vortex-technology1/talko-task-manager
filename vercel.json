{
  "version": 2,
  "headers": [
    {
      "source": "/css/sales-assistant.css",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "text/css; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://unpkg.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://accounts.google.com https://apis.google.com https://connect.facebook.net https://www.facebook.com https://*.facebook.com https://www.googletagmanager.com https://www.google-analytics.com https://analytics.tiktok.com; connect-src 'self' https://*.firebaseio.com wss://*.firebaseio.com https://*.googleapis.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://www.gstatic.com https://fonts.gstatic.com https://fonts.googleapis.com https://unpkg.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://api.telegram.org https://accounts.google.com https://apis.google.com https://api.anthropic.com https://api.openai.com https://api.qrserver.com https://*.cloudfunctions.net wss://s-usc1c-nss-2116.firebaseio.com wss://*.firebaseio.com https://api.novaposhta.ua https://api.monobank.ua https://chatapi.viber.com https://waba.360dialog.io https://connect.facebook.net https://www.facebook.com https://*.facebook.com https://www.googletagmanager.com https://www.google-analytics.com https://analytics.tiktok.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com data:; img-src 'self' data: blob: https: http:; frame-src 'self' https://accounts.google.com https://*.firebaseapp.com https://*.web.app https://*.firebasestorage.app https://www.facebook.com; worker-src 'self' blob:;"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/app.html"
    },
    {
      "source": "/api/stripe",
      "destination": "/api/stripe"
    },
    {
      "source": "/book/:companyId/g/:groupSlug",
      "destination": "/api/booking?action=page&companyId=:companyId&groupSlug=:groupSlug"
    },
    {
      "source": "/book/:companyId/:slug",
      "destination": "/api/booking?action=page&companyId=:companyId&slug=:slug"
    },
    {
      "source": "/book/:companyId",
      "destination": "/api/booking?action=profile&companyId=:companyId"
    },
    {
      "source": "/api/google-oauth",
      "destination": "/api/google-oauth"
    },
    {
      "source": "/s/:slug",
      "destination": "/api/site?slug=:slug"
    },
    {
      "source": "/api/webhook",
      "destination": "/api/webhook"
    },
    {
      "source": "/p/:companyId/:slug",
      "destination": "/pages/p/[companyId]/[slug]"
    },
    {
      "source": "/api/funnel-ai",
      "destination": "/api/funnel-ai"
    },
    {
      "source": "/api/ai-proxy",
      "destination": "/api/ai-proxy"
    }
  ],
  "functions": {
    "api/webhook.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/ai-proxy.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/weekly-report.js": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/site.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/funnel-ai.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/crm-reminders.js": {
      "maxDuration": 60,
      "memory": 256
    },
    "api/booking.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/google-oauth.js": {
      "maxDuration": 15,
      "memory": 128
    },
    "api/warehouse.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/stripe.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/utils.js": {
      "maxDuration": 10,
      "memory": 128
    }
  },
  "regions": [
    "fra1"
  ],
  "crons": [
    {
      "path": "/api/weekly-report",
      "schedule": "0 9 * * 0"
    },
    {
      "path": "/api/crm-reminders",
      "schedule": "0 8 * * *"
    }
  ]
}